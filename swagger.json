          "302": {
            "description": "Redirect to GitHub OAuth"
          }
        }
      }
    },
    "/": {
      "get": {
        "description": "Home page - shows login status",
        "summary": "Home page",
        "responses": {
          "200": {
            "description": "HTML page showing authentication status"
          }
        }
      }
    },
    "/health": {
      "get": {
        "description": "API health check endpoint",
        "summary": "Health check",
