      "post": {
        "tags": ["Products"],
        "description": "Create a new product (Requires GitHub OAuth authentication)",
        "summary": "Create new product - REQUIRES LOGIN",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["name", "description", "price", "category", "stock", "sku", "brand"],
              "properties": {
                "name": { "type": "string", "minLength": 3, "example": "Product Name" },
                "description": { "type": "string", "minLength": 10, "example": "Product description..." },
                "price": { "type": "number", "minimum": 0.01, "example": 29.99 },
                "category": { "type": "string", "enum": ["Electronics", "Clothing", "Books", "Home", "Sports", "Toys", "Food", "Other"] },
                "stock": { "type": "integer", "minimum": 0, "example": 50 },
                "sku": { "type": "string", "example": "SKU-12345" },
                "brand": { "type": "string", "example": "Brand Name" },
                "weight": { "type": "number", "minimum": 0 },
                "dimensions": { "type": "object" },
                "tags": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Product created successfully"
          },
          "400": {
            "description": "Bad Request - Validation error"
          },
          "401": {
            "description": "Unauthorized - Must be logged in with GitHub"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
